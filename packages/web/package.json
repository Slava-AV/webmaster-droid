{
  "name": "@webmaster-droid/web",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.2",
    "@webmaster-droid/contracts": "^0.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.1"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:styles",
    "build:js": "tsup src/index.tsx --format esm --dts --clean",
    "build:styles": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "@types/sanitize-html": "^2.16.0",
    "tailwindcss": "^4.1.0"
  },
  "description": "Unified web runtime and editable React components for webmaster-droid.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Slava-AV/webmaster-droid.git",
    "directory": "packages/web"
  },
  "bugs": {
    "url": "https://github.com/Slava-AV/webmaster-droid/issues"
  },
  "homepage": "https://github.com/Slava-AV/webmaster-droid#readme"
}
